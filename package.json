{
  "name": "amocrm-analytics",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@amocrm-analytics/api",
    "dev:web": "npm run dev --workspace=@amocrm-analytics/web",
    "build": "npm run build --workspace=@amocrm-analytics/api && npm run build --workspace=@amocrm-analytics/web",
    "typecheck": "npm run typecheck --workspace=@amocrm-analytics/api && npm run typecheck --workspace=@amocrm-analytics/web",
    "test": "npm test --workspace=@amocrm-analytics/api -- --runInBand",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:studio": "prisma studio --schema prisma/schema.prisma",
    "db:seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "prisma": "^5.22.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
