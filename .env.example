# PostgreSQL
POSTGRES_USER="amocrm"
POSTGRES_PASSWORD="CHANGE_ME_DB_PASSWORD"
POSTGRES_DB="amocrm_analytics"
POSTGRES_PORT="5433"
DATABASE_URL="postgresql://amocrm:CHANGE_ME_DB_PASSWORD@localhost:5433/amocrm_analytics?schema=public"

# API security
JWT_SECRET="CHANGE_ME_64_RANDOM_CHARACTERS_MINIMUM"
CREDENTIALS_ENCRYPTION_KEY="CHANGE_ME_64_HEX_CHARACTERS_RECOMMENDED"

# amoCRM private integration
AMOCRM_CLIENT_ID="CHANGE_ME_AMOCRM_CLIENT_ID"
AMOCRM_CLIENT_SECRET="CHANGE_ME_AMOCRM_CLIENT_SECRET"
AMOCRM_REDIRECT_URI="http://localhost:3000"
WEBHOOK_BASE_URL="https://analytics.example.internal/api/v1"
# Production data freshness is driven by amoCRM webhooks.
# This is only backup polling in case a webhook is missed. Local dev can set 2.
AMOCRM_SYNC_INTERVAL_MINUTES="10"

# HTTP
PORT="4000"
WEB_ORIGIN="http://localhost:3000"
VITE_API_URL="http://localhost:4000/api/v1"

# Telegram notifications
TELEGRAM_BOT_TOKEN="CHANGE_ME_TELEGRAM_BOT_TOKEN"

# Initial local admin seed
SEED_ADMIN_EMAIL="admin@example.internal"
SEED_ADMIN_PASSWORD="CHANGE_ME_ADMIN_PASSWORD"
