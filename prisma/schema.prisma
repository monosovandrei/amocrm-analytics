generator client {
  provider = "prisma-client-js"
  output   = "../apps/api/src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ROP
}

enum PlatformBusinessRole {
  OWNER
  ROP
  MANAGER
}

enum AmoConnectionStatus {
  ACTIVE
  INACTIVE
  ERROR
  SYNCING
}

enum SyncJobType {
  FULL
  INCREMENTAL
  WEBHOOK
}

enum SyncJobStatus {
  QUEUED
  RUNNING
  SUCCESS
  ERROR
}

enum CrmEntityType {
  LEAD
  CONTACT
  COMPANY
  CUSTOMER
  TASK
  NOTE
  EVENT
  CATALOG
  CATALOG_ELEMENT
  SOURCE
}

enum ReportSourceType {
  EVENT
  CURRENT
}

enum ConversionDenominator {
  PREVIOUS
  FIRST
}

enum ProbabilityMode {
  MANUAL
  AUTO
  HYBRID
}

enum ExportJobStatus {
  QUEUED
  RUNNING
  SUCCESS
  ERROR
}

enum NotificationChannel {
  TELEGRAM
}

enum DeliveryStatus {
  QUEUED
  SENT
  ERROR
  SKIPPED
}

enum AlertOperator {
  GT
  GTE
  LT
  LTE
  EQ
  NEQ
}

enum PlanPeriodType {
  DAY
  WEEK
  MONTH
  QUARTER
  YEAR
  CUSTOM
}

enum PlanTargetType {
  COMPANY
  GROUP
  MANAGER
}

enum QualitySeverity {
  INFO
  WARNING
  CRITICAL
}

enum ReportScheduleFrequency {
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM_CRON
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(ROP)
  businessRole PlatformBusinessRole @default(MANAGER)
  crmUserId    String?  @unique
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  crmUser          CrmUser? @relation(fields: [crmUserId], references: [id], onDelete: SetNull)
  dashboardLayouts DashboardLayout[]
  reportTemplates  ReportTemplate[]
  auditLogs        AuditLog[]
  telegramAccount  TelegramAccount?
  telegramChats    TelegramChat[]
  telegramLinkCodes TelegramLinkCode[]
  alertRules       AlertRule[]
  notificationDeliveries NotificationDelivery[]
  planSets         PlanSet[] @relation("PlanSetCreator")
  reportSchedules  ReportSchedule[]

  @@index([businessRole, isActive])
}

model AmoConnection {
  id                  String              @id @default(uuid())
  subdomain           String
  accountId           String?
  accountName         String?
  credentials         String
  webhookSecret       String              @unique
  status              AmoConnectionStatus @default(INACTIVE)
  syncIntervalMinutes Int                 @default(10)
  lastFullSyncAt      DateTime?
  lastIncrementalSyncAt DateTime?
  lastError           String?
  config              Json                @default("{}")
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  syncJobs      SyncJob[]
  webhookEvents WebhookEvent[]
}

model AmoAccountSnapshot {
  id         String   @id @default(uuid())
  externalId String? @unique
  name       String?
  subdomain  String?
  raw        Json     @default("{}")
  updatedAt  DateTime @updatedAt
}

model SyncJob {
  id           String        @id @default(uuid())
  connectionId String
  type         SyncJobType
  status       SyncJobStatus @default(QUEUED)
  startedAt    DateTime?
  finishedAt   DateTime?
  cursor        Json         @default("{}")
  stats         Json         @default("{}")
  error         String?
  createdAt     DateTime     @default(now())

  connection AmoConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId, createdAt])
  @@index([status, createdAt])
}

model WebhookEvent {
  id           String   @id @default(uuid())
  connectionId String
  entity       String
  action       String
  externalId   String?
  payload      Json     @default("{}")
  receivedAt   DateTime @default(now())
  processedAt  DateTime?
  status       String   @default("received")
  error        String?

  connection AmoConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId, receivedAt])
  @@index([entity, action])
}

model CrmGroup {
  id         String   @id @default(uuid())
  externalId String  @unique
  name       String
  isVisible  Boolean @default(true)
  raw        Json    @default("{}")

  users CrmUser[]
}

model CrmRole {
  id         String   @id @default(uuid())
  externalId String  @unique
  name       String
  raw        Json     @default("{}")
  updatedAt  DateTime @updatedAt
}

model CrmUser {
  id         String   @id @default(uuid())
  externalId String  @unique
  groupId    String?
  name       String
  email      String?
  isActive   Boolean @default(true)
  isVisible  Boolean @default(true)
  raw        Json    @default("{}")

  group CrmGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  platformUser User?
  telegramAccount TelegramAccount?
  telegramLinkCodes TelegramLinkCode[]
  deals Deal[]    @relation("ResponsibleDeals")
  tasks Task[]

  @@index([groupId])
}

model Pipeline {
  id                 String  @id @default(uuid())
  externalId         String  @unique
  name               String
  isArchived         Boolean @default(false)
  isShippingPipeline Boolean @default(false)
  raw                Json    @default("{}")

  stages PipelineStage[]
  deals  Deal[]
  lossReasons LossReason[]
}

model PipelineStage {
  id          String  @id @default(uuid())
  pipelineId  String
  externalId  String
  name        String
  position    Int
  color       String?
  isWon       Boolean @default(false)
  isLost      Boolean @default(false)
  isVisible   Boolean @default(true)
  raw         Json    @default("{}")

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals    Deal[]
  historyFrom DealStageHistory[] @relation("FromStage")
  historyTo   DealStageHistory[] @relation("ToStage")
  probabilities StageProbability[]

  @@unique([pipelineId, externalId])
  @@index([pipelineId, position])
}

model CustomFieldDefinition {
  id         String        @id @default(uuid())
  externalId String
  entityType CrmEntityType
  code       String?
  name       String
  type       String
  enums      Json          @default("[]")
  isVisible  Boolean       @default(true)
  raw        Json          @default("{}")

  @@unique([entityType, externalId])
}

model CrmTag {
  id         String        @id @default(uuid())
  externalId String
  entityType CrmEntityType
  name       String
  color      String?
  raw        Json          @default("{}")
  updatedAt  DateTime      @updatedAt

  @@unique([entityType, externalId])
  @@index([entityType, name])
}

model EntityLink {
  id                   String        @id @default(uuid())
  entityType           CrmEntityType
  entityExternalId     String
  linkedEntityType     String
  linkedEntityExternalId String
  metadata             Json          @default("{}")
  raw                  Json          @default("{}")
  updatedAt            DateTime      @updatedAt

  @@unique([entityType, entityExternalId, linkedEntityType, linkedEntityExternalId])
  @@index([entityType, entityExternalId])
  @@index([linkedEntityType, linkedEntityExternalId])
}

model Contact {
  id         String   @id @default(uuid())
  externalId String  @unique
  name       String
  phone      String?
  email      String?
  customFields Json  @default("{}")
  raw        Json     @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  deals Deal[]
}

model CrmCompany {
  id         String   @id @default(uuid())
  externalId String  @unique
  name       String
  customFields Json  @default("{}")
  raw        Json     @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model CustomerStatus {
  id         String   @id @default(uuid())
  externalId String  @unique
  name       String
  sort       Int      @default(0)
  color      String?
  raw        Json     @default("{}")
  updatedAt  DateTime @updatedAt

  customers Customer[]
}

model CustomerSegment {
  id         String   @id @default(uuid())
  externalId String  @unique
  name       String
  raw        Json     @default("{}")
  updatedAt  DateTime @updatedAt
}

model Customer {
  id           String   @id @default(uuid())
  externalId   String   @unique
  statusId     String?
  name         String
  nextPrice    Decimal  @default(0)
  periodicity  Int?
  responsibleId String?
  customFields Json     @default("{}")
  raw          Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  status       CustomerStatus? @relation(fields: [statusId], references: [id], onDelete: SetNull)
  transactions CustomerTransaction[]

  @@index([statusId])
  @@index([responsibleId])
}

model CustomerTransaction {
  id         String   @id @default(uuid())
  externalId String  @unique
  customerId String?
  amount     Decimal  @default(0)
  comment    String?
  raw        Json     @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([createdAt])
}

model LossReason {
  id         String @id @default(uuid())
  pipelineId String
  externalId String
  name       String
  raw        Json   @default("{}")

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals    Deal[]

  @@unique([pipelineId, externalId])
}

model Deal {
  id              String   @id @default(uuid())
  externalId      String   @unique
  pipelineId      String
  stageId         String
  responsibleId   String?
  contactId       String?
  lossReasonId    String?
  title           String
  amount          Decimal  @default(0)
  currency        String   @default("RUB")
  source          String?
  tags            String[] @default([])
  customFields    Json     @default("{}")
  raw             Json     @default("{}")
  closedAt        DateTime?
  expectedCloseAt DateTime?
  createdAt       DateTime
  updatedAt       DateTime
  deletedAt       DateTime?

  pipeline    Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Restrict)
  stage       PipelineStage @relation(fields: [stageId], references: [id], onDelete: Restrict)
  responsible CrmUser?      @relation("ResponsibleDeals", fields: [responsibleId], references: [id], onDelete: SetNull)
  contact     Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  lossReason  LossReason?   @relation(fields: [lossReasonId], references: [id], onDelete: SetNull)
  stageHistory DealStageHistory[]
  tasks        Task[]
  notes        Note[]
  events       CrmEvent[]
  products     DealProduct[]

  @@index([pipelineId, stageId])
  @@index([responsibleId])
  @@index([closedAt])
  @@index([updatedAt])
}

model DealStageHistory {
  id          String   @id @default(uuid())
  dealId      String
  fromStageId String?
  toStageId   String
  movedAt     DateTime
  movedById   String?
  source      String   @default("sync")
  raw         Json     @default("{}")

  deal      Deal           @relation(fields: [dealId], references: [id], onDelete: Cascade)
  fromStage PipelineStage? @relation("FromStage", fields: [fromStageId], references: [id], onDelete: SetNull)
  toStage   PipelineStage  @relation("ToStage", fields: [toStageId], references: [id], onDelete: Restrict)

  @@index([dealId, movedAt])
  @@index([toStageId, movedAt])
}

model DealResponsibleHistory {
  id             String   @id @default(uuid())
  dealId         String
  fromUserId     String?
  toUserId       String?
  changedAt      DateTime
  source         String   @default("sync")
  raw            Json     @default("{}")

  @@index([dealId, changedAt])
}

model Task {
  id            String   @id @default(uuid())
  externalId    String   @unique
  dealId        String?
  responsibleId String?
  title         String
  typeId        Int?
  typeName      String?
  dueAt         DateTime?
  completedAt   DateTime?
  isCompleted   Boolean  @default(false)
  raw           Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  deal        Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  responsible CrmUser? @relation(fields: [responsibleId], references: [id], onDelete: SetNull)
}

model Note {
  id         String   @id @default(uuid())
  externalId String  @unique
  dealId     String?
  type       String
  text       String?
  createdAt  DateTime
  raw        Json     @default("{}")

  deal Deal? @relation(fields: [dealId], references: [id], onDelete: SetNull)
}

model CrmEvent {
  id         String   @id @default(uuid())
  externalId String  @unique
  dealId     String?
  type       String
  valueBefore Json?
  valueAfter  Json?
  createdAt  DateTime
  raw        Json     @default("{}")

  deal Deal? @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([type, createdAt])
}

model DealProduct {
  id        String   @id @default(uuid())
  dealId    String
  externalId String?
  name      String
  sku       String?
  quantity  Decimal  @default(1)
  price     Decimal  @default(0)
  raw       Json     @default("{}")

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
}

model Catalog {
  id              String   @id @default(uuid())
  externalId      String   @unique
  name            String
  type            String?
  sort            Int      @default(0)
  canAddElements  Boolean  @default(false)
  canShowInCards  Boolean  @default(false)
  canLinkMultiple Boolean  @default(false)
  raw             Json     @default("{}")
  updatedAt       DateTime @updatedAt

  elements CatalogElement[]
}

model CatalogElement {
  id           String   @id @default(uuid())
  catalogId    String
  externalId   String
  name         String
  customFields Json     @default("{}")
  raw          Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  catalog Catalog @relation(fields: [catalogId], references: [id], onDelete: Cascade)

  @@unique([catalogId, externalId])
  @@index([catalogId])
}

model CrmSource {
  id         String   @id @default(uuid())
  externalId String  @unique
  name       String
  pipelineId String?
  originCode String?
  isDefault  Boolean  @default(false)
  raw        Json     @default("{}")
  updatedAt  DateTime @updatedAt

  @@index([pipelineId])
}

model ReportTemplate {
  id          String           @id @default(uuid())
  userId      String?
  name        String
  sourceType  ReportSourceType
  config      Json             @default("{}")
  position    Int              @default(0)
  isShared    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  alertRules AlertRule[]
  reportSchedules ReportSchedule[]
}

model DashboardLayout {
  id        String   @id @default(uuid())
  userId    String
  name      String
  config    Json     @default("{}")
  isDefault Boolean  @default(false)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ForecastSettings {
  id                     String          @id @default(uuid())
  closingStageId         String?
  shippingPipelineId     String?
  shippingSuccessStageId String?
  probabilityMode        ProbabilityMode @default(HYBRID)
  minSampleSize          Int             @default(3)
  updatedAt              DateTime        @updatedAt
}

model StageProbability {
  id             String   @id @default(uuid())
  stageId        String
  manualPercent  Decimal?
  autoPercent    Decimal?
  sampleSize     Int      @default(0)
  confidence     Decimal  @default(0)
  updatedAt      DateTime @updatedAt

  stage PipelineStage @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@unique([stageId])
}

model ExportJob {
  id        String          @id @default(uuid())
  status    ExportJobStatus @default(QUEUED)
  reportConfig Json         @default("{}")
  filePath  String?
  error     String?
  createdAt DateTime        @default(now())
  finishedAt DateTime?
}

model TelegramAccount {
  id        String   @id @default(uuid())
  userId    String?  @unique
  crmUserId String?  @unique
  chatId    String   @unique
  username  String?
  firstName String?
  lastName  String?
  isActive  Boolean  @default(true)
  linkedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  crmUser CrmUser? @relation(fields: [crmUserId], references: [id], onDelete: Cascade)
  deliveries NotificationDelivery[]
}

model TelegramChat {
  id        String   @id @default(uuid())
  userId    String
  chatId    String   @unique
  type      String   @default("group")
  title     String?
  username  String?
  isActive  Boolean  @default(true)
  linkedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries NotificationDelivery[]

  @@index([userId, isActive])
}

model TelegramLinkCode {
  id        String   @id @default(uuid())
  userId    String?
  crmUserId String?
  code      String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  crmUser CrmUser? @relation(fields: [crmUserId], references: [id], onDelete: Cascade)

  @@index([code, expiresAt])
  @@index([userId, createdAt])
  @@index([crmUserId, createdAt])
}

model AlertRule {
  id                String        @id @default(uuid())
  userId            String?
  reportTemplateId  String?
  name              String
  description       String?
  enabled           Boolean       @default(true)
  metricKey         String?
  operator          AlertOperator @default(GTE)
  threshold         Decimal?
  condition         Json          @default("{}")
  recipients        Json          @default("[]")
  checkEveryMinutes Int           @default(15)
  cooldownMinutes   Int           @default(60)
  lastCheckedAt     DateTime?
  lastTriggeredAt   DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user           User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  reportTemplate ReportTemplate? @relation(fields: [reportTemplateId], references: [id], onDelete: SetNull)
  events         AlertEvent[]

  @@index([enabled, lastCheckedAt])
  @@index([userId])
  @@index([reportTemplateId])
}

model AlertEvent {
  id          String         @id @default(uuid())
  alertRuleId String
  status      DeliveryStatus @default(QUEUED)
  value       Decimal?
  message     String
  payload     Json           @default("{}")
  createdAt   DateTime       @default(now())
  sentAt      DateTime?

  alertRule  AlertRule @relation(fields: [alertRuleId], references: [id], onDelete: Cascade)
  deliveries NotificationDelivery[]

  @@index([alertRuleId, createdAt])
  @@index([status, createdAt])
}

model NotificationDelivery {
  id                String              @id @default(uuid())
  eventKey          String?             @unique
  userId            String?
  telegramAccountId String?
  telegramChatId    String?
  alertEventId      String?
  channel           NotificationChannel @default(TELEGRAM)
  status            DeliveryStatus      @default(QUEUED)
  message           String
  payload           Json                @default("{}")
  error             String?
  sentAt            DateTime?
  createdAt         DateTime            @default(now())

  user            User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  telegramAccount TelegramAccount? @relation(fields: [telegramAccountId], references: [id], onDelete: SetNull)
  telegramChat    TelegramChat?    @relation(fields: [telegramChatId], references: [id], onDelete: SetNull)
  alertEvent      AlertEvent?      @relation(fields: [alertEventId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([telegramAccountId])
  @@index([telegramChatId])
}

model NotificationTemplate {
  id        String   @id @default(uuid())
  eventType String   @unique
  name      String
  body      String
  recipients Json    @default("[]")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlanSet {
  id          String   @id @default(uuid())
  name        String
  year        Int?
  isActive    Boolean  @default(true)
  version     Int      @default(1)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User? @relation("PlanSetCreator", fields: [createdById], references: [id], onDelete: SetNull)
  items     PlanItem[]
  imports   PlanImport[]

  @@index([isActive, year])
  @@index([createdById])
}

model PlanItem {
  id          String         @id @default(uuid())
  planSetId   String
  periodType  PlanPeriodType
  periodStart DateTime
  periodEnd   DateTime
  targetType  PlanTargetType
  targetId    String?
  targetName  String?
  metricKey   String
  metricName  String
  value       Decimal
  unit        String         @default("number")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  planSet PlanSet @relation(fields: [planSetId], references: [id], onDelete: Cascade)

  @@index([planSetId, periodStart, periodEnd])
  @@index([targetType, targetId])
  @@index([metricKey])
}

model PlanImport {
  id           String   @id @default(uuid())
  planSetId    String?
  fileName     String
  status       String   @default("uploaded")
  rowsTotal    Int      @default(0)
  rowsAccepted Int      @default(0)
  errors       Json     @default("[]")
  createdAt    DateTime @default(now())

  planSet PlanSet? @relation(fields: [planSetId], references: [id], onDelete: SetNull)

  @@index([planSetId, createdAt])
}

model QualityRule {
  id          String          @id @default(uuid())
  code        String          @unique
  name        String
  description String?
  severity    QualitySeverity @default(WARNING)
  enabled     Boolean         @default(true)
  config      Json            @default("{}")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  snapshots  QualitySnapshot[]
  violations QualityViolation[]

  @@index([enabled, severity])
}

model QualitySnapshot {
  id              String   @id @default(uuid())
  ruleId          String?
  managerId       String?
  managerName     String?
  groupId         String?
  groupName       String?
  score           Decimal?
  violationsCount Int      @default(0)
  payload         Json     @default("{}")
  createdAt       DateTime @default(now())

  rule QualityRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@index([ruleId, createdAt])
  @@index([managerId, createdAt])
  @@index([groupId, createdAt])
}

model QualityViolation {
  id          String          @id @default(uuid())
  ruleId      String
  managerId   String?
  managerName String?
  groupId     String?
  groupName   String?
  dealId      String?
  taskId      String?
  severity    QualitySeverity
  message     String
  payload     Json            @default("{}")
  detectedAt  DateTime        @default(now())
  resolvedAt  DateTime?

  rule QualityRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId, detectedAt])
  @@index([managerId, detectedAt])
  @@index([resolvedAt])
}

model ReportSchedule {
  id               String                  @id @default(uuid())
  userId           String
  reportTemplateId String?
  name             String
  enabled          Boolean                 @default(true)
  frequency        ReportScheduleFrequency @default(DAILY)
  cron             String?
  timeOfDay        String                  @default("09:00")
  timezone         String                  @default("Europe/Moscow")
  recipients       Json                    @default("[]")
  format           String                  @default("telegram")
  nextRunAt        DateTime?
  lastRunAt        DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  reportTemplate ReportTemplate? @relation(fields: [reportTemplateId], references: [id], onDelete: SetNull)
  logs           ReportDeliveryLog[]

  @@index([enabled, nextRunAt])
  @@index([userId])
  @@index([reportTemplateId])
}

model ReportDeliveryLog {
  id         String         @id @default(uuid())
  scheduleId String
  status     DeliveryStatus @default(QUEUED)
  message    String?
  payload    Json           @default("{}")
  error      String?
  sentAt     DateTime?
  createdAt  DateTime       @default(now())

  schedule ReportSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId, createdAt])
  @@index([status, createdAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}
